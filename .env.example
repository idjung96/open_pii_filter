# Copy to .env and fill in real values. NEVER commit .env.

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/<database>
DATABASE_URL_SYNC=postgresql+psycopg://<user>:<password>@<host>:5432/<database>
DB_SCHEMA=pii

# --- Redis ---
REDIS_URL=redis://<host>:6379/0

# --- ClamAV ---
CLAMAV_HOST=<host>
CLAMAV_PORT=3310

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Phase 3 — Auth & rate limiting ---
# Comma-separated CIDRs for the global IP allowlist; empty = no restriction.
IP_ALLOWLIST=
# Hard cap on HTTP request body (bytes); enforced by BodySizeLimitMiddleware.
MAX_REQUEST_BODY_BYTES=1048576
# Per-IP fallback for unauthenticated traffic (requests/min).
IP_RATE_PER_MINUTE=10
# Honour X-Forwarded-For only when behind a trusted reverse proxy (e.g. nginx).
TRUST_FORWARDED_FOR=false

# --- Phase 4 — Webhook callbacks ---
WEBHOOK_SIGNING_SECRET=
ATTACHMENT_FETCH_TIMEOUT_SECONDS=30
WEBHOOK_POST_TIMEOUT_SECONDS=15

# --- Phase 5 — OCR & masked artifacts ---
OCR_ENGINE=vlm
VLM_ENDPOINT=http://<vlm-host>:18000/v1
VLM_MODEL_ID=Qwen/Qwen3.5-27B-GPTQ-Int4
VLM_API_KEY=
OCR_REQUEST_TIMEOUT_SECONDS=120
MASKED_IMAGE_DIR=data/masked
MASKED_IMAGE_RETENTION_HOURS=24
PUBLIC_BASE_URL=

# --- Phase 6 — Privacy & audit ---
# Hex-encoded 32-byte AES-256 master key (required for encrypt_str / decrypt_str).
PII_ENCRYPTION_KEY=
PII_ENCRYPTION_KEY_ID=1
# JSON-encoded mapping of retired key_id → hex master key for rotation grace.
PII_ENCRYPTION_OLD_KEYS=
DETECTION_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=365
# CIDR allowlist for /v1/admin/*. Empty → admin routers not mounted (404).
# Phase 8 — the metrics endpoint is also gated by the same allowlist.
ADMIN_IP_ALLOWLIST=

# --- Phase 7 — Feedback alerter ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
# CSV of recipients
ALERT_EMAIL_TO=
FEEDBACK_ALERT_THRESHOLD=10
FEEDBACK_ALERT_INTERVAL_SECONDS=3600

# --- Phase 7 — Privacy notice template variables ---
COMPANY_NAME=
COMPANY_CONTACT_EMAIL=
COMPANY_CONTACT_PHONE=
DATA_PROTECTION_OFFICER_NAME=
DATA_PROTECTION_OFFICER_EMAIL=

# --- PoC (shadow) mode ---
# true 로 설정하면 분석은 정상 수행되지만 응답은 항상 PASS(OK-0000) 로
# 강제되고, 실제 판정은 POC_LOG_FILE 에 JSON Lines 로 기록된다. 상용 PII
# filter 와 병행 운영하며 검출률을 사후 비교할 때 사용한다.
POC_MODE=false
POC_LOG_FILE=logs/poc_shadow.log
